<Page x:Class="TaskManager_Toshmatov.View.Main"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TaskManager_Toshmatov.View"
      xmlns:elements="clr-namespace:TaskManager_Toshmatov.View.Items"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Main">
    <Page.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF4FC318" />
            <Setter Property="BorderBrush" Value="#FF4FC318" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Page.Resources>
    <Grid>
        <ListView ItemsSource="{Binding Tasks}"  HorizontalContentAlignment="Stretch"  Margin="0,0,0,40">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <elements:Item DataContext="{Binding}"/>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <Button Style="{StaticResource Update}" Command="{Binding OnAddTask}" Content="Добавить" Height="25" Width="70" 
                VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,10,10" Grid.Column="1">
            <Button.Effect>
                <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3"></DropShadowEffect>
            </Button.Effect>
        </Button>
    </Grid>
</Page>
